# Configuración profesional para el dashboard de gestión de citas

# Configuración del Supervisor para SENA
supervisor_email="supervisor@sena.edu.co"
supervisor_phone="+57 601 123 4567"
pais_codigo="CO"
zona_horaria="America/Bogota"
moneda="COP"
idioma="es"

# Configuración de Sesión y Seguridad
session_timeout_minutes=1440  # 24 horas
csrf_enabled=true
rate_limiting_enabled=true
max_login_attempts=5
account_lockout_minutes=30
bcrypt_rounds=12

# Configuración de Base de Datos SQL
db_host="localhost"
db_port="5432"
db_name="gestion_citas"
db_user="postgres"
db_pass="tu_contraseña_aqui"
db_ssl_mode="require"

# Configuración de Email SMTP
smtp_server="smtp.gmail.com"
smtp_port="587"
smtp_user="noreply@sena.edu.co"
smtp_pass="tu_contraseña_app_aqui"
smtp_from="SENA Bienestar <noreply@sena.edu.co>"
email_template_dir="./templates/emails"

# Configuración de Almacenamiento de Archivos
uploaddir="./public/uploads"
max_file_size_mb=10
allowed_image_types="jpg jpeg png gif"

# Configuración del Sistema de Citas
appointment_duration_minutes=60
max_concurrent_appointments_per_day=3
cancellation_deadline_hours=24
no_show_penalty_points=1

# Configuración de Análisis y Métricas
analytics_enabled=true
analytics_retention_days=365
backup_frequency_hours=24
log_retention_days=90

# Configuración del Sistema
app_name="SENA Bienestar - Gestión de Citas"
app_version="2.0.0"
app_url="https://gestion-citas.sena.edu.co"
maintenance_mode=false
debug_mode=false

# Configuración de Mercado Pago (para futuras implementaciones)
paypal_enabled=false
mercadopago_enabled=true
razorpay_enabled=false

# Configuración de Notificaciones
push_notification_enabled=true
sms_notification_enabled=true
email_notification_enabled=true
in_app_notification_enabled=true

# Configuración de Colores Institucionales SENA
sena_green="#39a900"
sena_green_dark="#2d8a00"
sena_green_light="#dcfce7"
sena_gray="#f5f5f5"
sena_gray_dark="#1a1a1a"
sena_white="#ffffff"

# Gradientes SENA Benestar
gradient_primary="linear-gradient(135deg, var(--sena-green) 0%, #2d8a00 100%)"
gradient_secondary="linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%)"

# Configuración de Botones y Componentes
border_radius_sm="4px"
border_radius_md="8px"
border_radius_lg="12px"
spacing_unit="1rem"
container_max_width="1200px"

# Configuración de Responsive Design
breakpoint_sm="640px"
breakpoint_md="768px"
breakpoint_lg="1024px"
breakpoint_xl="1280px"

# Configuración de API
api_rate_limit="100/hour"
api_rate_limit_auth="5/minute"
api_cors_origins="https://gestion-citas.sena.edu.co,http://localhost:3000"

# Configuración de Cache
redis_enabled=true
cache_ttl_minutes="60"
static_cache_ttl_days="30"

# Configuración de Monitoreo y Alertas
health_check_endpoint="/health"
metrics_endpoint="/metrics"
alert_email="admin@sena.edu.co"
monitor_nodes=3

# Configuración de Versiones y Actualizaciones
auto_update_enabled=false
version_check_frequency_hours="12"
changelog_repository="https://github.com/SENA-Digital/gestion-citas/releases"

# Configuración de Backup y Recuperación
database_backup_enabled=true
file_backup_enabled=true
backup_storage_bucket="gestion-citas-backups"
backup_retention_days="30"
restore_point_retention_hours="24"

# Configuración de Privacidad y Cookies
cookie_consent_required=true
cookie_expiration_days=365
analytics_consent_required=true
personalization_consent_optional=true

# Configuración de Monitoreo de Desempeño
database_query_timeout_seconds=30
cache_hit_ratio_threshold=95
memory_usage_threshold_percent=85
cpu_usage_threshold_percent=80

# Configuración de Tareas en Segundo Plano
queue_processor_enabled=true
queue_cleanup_interval_minutes="15"
max_retry_attempts=3
retry_delay_seconds=300

# Configuración de Funcionamiento SENA
working_hours_start="08:00"
working_hours_end="18:00"
working_days="lun,vie"
next_day_working_hours_start="08:00"

# Configuración de Notificaciones
notificacion_email_programada_enabled=true
notificacion_sms_programada_enabled=true
notificacion_push_programada_enabled=true
notification_priority_enabled=true

# Configuración de Bitácora
audit_log_enabled=true
audit_retention_days="180"
sensitive_data_logging_enabled=false
log_sensitive_fields="password,token,session"

# Configuración de Capacidades Múltiples
multi_idioma_enabled=true
idiomas_disponibles="es,en"
default_idioma="es"
system_datetime_format="YYYY-MM-DD HH:mm:ss"
system_date_format="DD/MM/YYYY"
