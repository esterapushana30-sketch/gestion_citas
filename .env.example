# =============================================================
# GESTIÓN DE CITAS - Variables de Entorno
# =============================================================
# Copia este archivo como .env y reemplaza los valores
# cp .env.example .env

# --- Supabase ---
# Obtén estos valores desde https://supabase.com > tu proyecto > Settings > API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Si no se configuran, la app entra en modo demo con cliente simulado.
# No se podrán crear usuarios ni acceder a datos reales.
